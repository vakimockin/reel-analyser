APIFY_TOKEN=your_apify_token_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/insta_analyzer
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional AI tuning
AI_MAX_REELS=15
OPENAI_FRAMES_PER_REEL=6
AI_THUMBNAIL_ONLY=false
AI_NICHE_SUMMARY_ENABLED=true
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Telegram bot / notifications
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ALLOWED_CHAT_IDS=
BACKEND_BASE_URL=http://localhost:8000

# Frontend runtime API URL (for Vite build, e.g. Render Static Site)
VITE_API_BASE_URL=http://localhost:8000
